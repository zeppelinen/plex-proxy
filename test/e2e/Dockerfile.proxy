FROM golang:1.22-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /plex-proxy ./cmd/plex-proxy

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends openssh-client ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=build /plex-proxy /usr/local/bin/plex-proxy
ENTRYPOINT ["/usr/local/bin/plex-proxy"]
