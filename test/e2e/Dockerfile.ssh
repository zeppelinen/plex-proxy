FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends openssh-server && rm -rf /var/lib/apt/lists/*
RUN useradd -m -s /bin/sh tunnel && mkdir -p /run/sshd /home/tunnel/.ssh && chown -R tunnel:tunnel /home/tunnel/.ssh && chmod 700 /home/tunnel/.ssh
COPY .tmp/id_ed25519.pub /home/tunnel/.ssh/authorized_keys
RUN chown tunnel:tunnel /home/tunnel/.ssh/authorized_keys && chmod 600 /home/tunnel/.ssh/authorized_keys
EXPOSE 22
CMD ["/usr/sbin/sshd", "-D", "-e", "-o", "PasswordAuthentication=no", "-o", "PermitRootLogin=no", "-o", "AllowTcpForwarding=yes", "-o", "GatewayPorts=no"]
